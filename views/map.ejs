<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head', {
  title: 'Shadow Construction — Job Site Map',
  fontsUrl: 'https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap',
  cssFile: 'map.css'
}) %>
</head>
<body>

<nav class="topnav">
  <a href="/" class="topnav-back">← Home</a>
  <div class="topnav-divider"></div>
  <a href="/" class="topnav-logo">SHADOW <span>CONST.</span></a>
  <span class="topnav-label">JOB MAP</span>
  <div class="topnav-links">
    <a href="/wiki" class="topnav-link">📖 Wiki</a>
    <a href="/fleet" class="topnav-link">🚛 Fleet</a>
  </div>
</nav>

<div class="map-layout">

  <!-- ── SIDEBAR KEY ── -->
  <aside class="map-sidebar">

    <div class="sidebar-block">
      <div class="sidebar-eyebrow">// Liberty County</div>
      <div class="sidebar-title">JOB SITE <span>MAP</span></div>
      <div class="sidebar-sub">Active construction zones, road closures, and equipment staging areas.</div>
    </div>

    <div class="sidebar-block">
      <div class="stat-row">
        <div class="stat-chip">
          <div class="stat-chip-num" id="statActive">—</div>
          <div class="stat-chip-label">Active</div>
        </div>
        <div class="stat-chip">
          <div class="stat-chip-num" id="statClosure">—</div>
          <div class="stat-chip-label">Closures</div>
        </div>
        <div class="stat-chip">
          <div class="stat-chip-num" id="statTotal">—</div>
          <div class="stat-chip-label">Total Jobs</div>
        </div>
      </div>
    </div>

    <div class="sidebar-block">
      <div class="sidebar-eyebrow">// Map Legend</div>
      <div id="legendList">
        <div class="legend-item" data-type="active"   onclick="toggleLayer(this)"><div class="legend-dot active"></div>  <span class="legend-label">Active Site</span>  <span class="legend-count" id="lc-active">0</span></div>
        <div class="legend-item" data-type="closure"  onclick="toggleLayer(this)"><div class="legend-dot closure"></div> <span class="legend-label">Road Closure</span> <span class="legend-count" id="lc-closure">0</span></div>
        <div class="legend-item" data-type="staging"  onclick="toggleLayer(this)"><div class="legend-dot staging"></div> <span class="legend-label">Staging Area</span> <span class="legend-count" id="lc-staging">0</span></div>
        <div class="legend-item" data-type="planned"  onclick="toggleLayer(this)"><div class="legend-dot planned"></div> <span class="legend-label">Planned</span>       <span class="legend-count" id="lc-planned">0</span></div>
        <div class="legend-item" data-type="complete" onclick="toggleLayer(this)"><div class="legend-dot complete"></div><span class="legend-label">Complete</span>      <span class="legend-count" id="lc-complete">0</span></div>
        <div class="legend-item" data-type="hazard"   onclick="toggleLayer(this)"><div class="legend-dot hazard"></div>  <span class="legend-label">Hazard Zone</span>  <span class="legend-count" id="lc-hazard">0</span></div>
      </div>
    </div>

    <div class="sidebar-block" style="flex:1;">
      <div class="sidebar-eyebrow">// Job Sites</div>
      <div id="jobListEl"></div>
    </div>

  </aside>

  <!-- ── MAP AREA ── -->
  <main class="map-main" id="mapMain">

    <!-- zoom controls -->
    <div class="map-toolbar">
      <button class="map-btn" onclick="zoom(0.2)" title="Zoom In">+</button>
      <button class="map-btn" onclick="zoom(-0.2)" title="Zoom Out">−</button>
      <div class="map-btn-sep"></div>
      <button class="map-btn" onclick="resetView()" title="Reset View" style="font-size:12px;">⌖</button>
    </div>

    <!-- coordinates indicator -->
    <div class="map-coords" id="mapCoords">ER:LC — Liberty County</div>

    <!-- map canvas -->
    <div class="map-canvas-wrap" id="canvasWrap">
      <div class="map-canvas-inner" id="canvasInner">

        <svg id="mapSVG" viewBox="0 0 1000 933" width="1000" height="933" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="glow-y"><feGaussianBlur stdDeviation="3" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            <filter id="glow-r"><feGaussianBlur stdDeviation="5" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          </defs>

          <!-- ── MAP IMAGE BACKGROUND ── -->
          <image href="/images/lcmap.jpg" x="0" y="0" width="1000" height="933" preserveAspectRatio="xMidYMid meet"/>

          <!-- ── SHADOW CONSTRUCTION BASE — Postals 303 / 304 ── -->
          <g id="sc-base" style="cursor:pointer;" onclick="openDetail('base')">
            <circle cx="308" cy="403" r="22" fill="#f5c400" opacity="0.15"/>
            <circle cx="308" cy="403" r="16" fill="none" stroke="#f5c400" stroke-width="2" opacity="0.6" stroke-dasharray="5,3"/>
            <rect x="296" y="391" width="24" height="24" rx="3" fill="#f5c400" stroke="#0c0e0f" stroke-width="2"/>
            <text x="308" y="407" fill="#0c0e0f" font-family="'Black Ops One',sans-serif" font-size="11" font-weight="900" text-anchor="middle">SC</text>
            <rect x="274" y="418" width="68" height="14" rx="2" fill="#0c0e0fee"/>
            <text x="308" y="429" fill="#f5c400" font-family="'Share Tech Mono',monospace" font-size="8" letter-spacing="1" text-anchor="middle" font-weight="700">HQ · 303 / 304</text>
          </g>

          <!-- ── JOB MARKERS rendered by JS ── -->
          <g id="markersLayer"></g>
        </svg>

      </div>
    </div>

    <div class="caution-strip"></div>

    <!-- ── DETAIL PANEL ── -->
    <div class="detail-panel" id="detailPanel">
      <div class="detail-header">
        <span class="detail-type-badge" id="detailBadge"></span>
        <button class="detail-close" onclick="closeDetail()">✕</button>
      </div>
      <div class="detail-body">
        <div class="detail-name"  id="detailName"></div>
        <div class="detail-desc"  id="detailDesc"></div>
        <div class="detail-grid" id="detailGrid"></div>
      </div>
    </div>

  </main>
</div>

<script>
// ── JOB DATA ──────────────────────────────────────────────────────────────────
// Coordinates in 1000x933 SVG space — based on Liberty County postal map (dark version)
// Display image was 2000x1866; SVG coords = display coords / 2
const JOBS = [
  {
    id:1, name:"Colonial Drive Reconstruction", type:"active",
    x:296, y:243,
    desc:"Full road reconstruction near postals 601–604. Lane closures in effect — flaggers on site.",
    crew:8, foreman:"J. Reyes", session:"Mon / Fri", zone:"P601–604"
  },
  {
    id:2, name:"Independence Pkwy Resurfacing", type:"closure",
    x:188, y:341,
    desc:"Milling and repaving near postals 216–219. One lane open each direction with flagging.",
    crew:5, foreman:"T. Walsh", session:"Monday", zone:"P216–219"
  },
  {
    id:3, name:"Orchard Blvd Utility Cut", type:"active",
    x:152, y:369,
    desc:"Utility trench near postals 212–213. Road cut active — barriers deployed.",
    crew:6, foreman:"M. Chen", session:"Wed / Sat", zone:"P212–213"
  },
  {
    id:4, name:"Madison Court Resurfacing", type:"planned",
    x:286, y:419,
    desc:"Full resurfacing near postals 300–301. Work begins next session cycle.",
    crew:0, foreman:"TBD", session:"Pending", zone:"P300–301"
  },
  {
    id:5, name:"Spring Creek Rd Pipeline", type:"active",
    x:273, y:129,
    desc:"Utility trench for water main near postal 903. Flaggers active.",
    crew:4, foreman:"R. Okafor", session:"Wednesday", zone:"P903"
  },
  {
    id:6, name:"Hwy 55 Lane Closure", type:"closure",
    x:354, y:278,
    desc:"Highway 55 near postal 510 closed for barrier installation and lane repainting.",
    crew:3, foreman:"S. Park", session:"Friday", zone:"P510"
  },
  {
    id:7, name:"Postal 908 Vault — Complete", type:"complete",
    x:306, y:175,
    desc:"Underground utility vault replacement near postal 908 — work complete, road reopened.",
    crew:0, foreman:"J. Reyes", session:"—", zone:"P908"
  },
  {
    id:8, name:"Oak Valley Dr — Staging", type:"staging",
    x:813, y:625,
    desc:"Equipment staging zone near postal 1201. Crane on site — caution advised.",
    crew:2, foreman:"A. Torres", session:"Saturday", zone:"P1201"
  },
  {
    id:9, name:"Freedom Ave Sewer Line", type:"active",
    x:136, y:393,
    desc:"Sewer main replacement near postals 205–208. Heavy excavation — expect detours.",
    crew:5, foreman:"D. Kim", session:"Mon / Wed", zone:"P205–208"
  },
  {
    id:10, name:"Fairfax Rd Widening", type:"planned",
    x:132, y:325,
    desc:"Planned widening near postals 401–402. Awaiting permits and traffic study.",
    crew:0, foreman:"TBD", session:"Pending", zone:"P401–402"
  },
  {
    id:11, name:"Postal 504 — Hazard Zone", type:"hazard",
    x:295, y:283,
    desc:"Unstable ground detected near postals 504–505. Area cordoned — no vehicles or workers.",
    crew:0, foreman:"Safety Off.", session:"—", zone:"P504–505"
  }
];

// ── CONFIG ────────────────────────────────────────────────────────────────────
const COLORS = {
  active:  '#f5c400',
  closure: '#e8730a',
  staging: '#64b5f6',
  planned: '#9e9e9e',
  complete:'#3ddc6e',
  hazard:  '#d94f2b'
};
const LABELS = {
  active:'ACTIVE SITE', closure:'ROAD CLOSURE', staging:'STAGING AREA',
  planned:'PLANNED', complete:'COMPLETE', hazard:'HAZARD ZONE'
};

// ── STATE ─────────────────────────────────────────────────────────────────────
let scale = 1, tx = 0, ty = 0;
let dragging = false, startX = 0, startY = 0, startTx = 0, startTy = 0;
const hiddenTypes = new Set();
let activeJob = null;

// ── INIT ──────────────────────────────────────────────────────────────────────
function init() {
  buildMarkers();
  buildJobList();
  updateStats();
  fitMap();
}

function fitMap() {
  const wrap  = document.getElementById('canvasWrap');
  const ww = wrap.clientWidth, wh = wrap.clientHeight;
  const sw = 1000, sh = 933;
  scale = Math.min(ww / sw, wh / sh) * 0.96;
  tx = (ww - sw * scale) / 2;
  ty = (wh - sh * scale) / 2;
  applyTransform();
}

// ── MARKERS ───────────────────────────────────────────────────────────────────
function buildMarkers() {
  const layer = document.getElementById('markersLayer');
  layer.innerHTML = '';
  JOBS.forEach(job => {
    const c = COLORS[job.type];
    const g = document.createElementNS('http://www.w3.org/2000/svg','g');
    g.setAttribute('class','marker-group');
    g.setAttribute('data-id', job.id);
    g.setAttribute('data-type', job.type);
    g.innerHTML = `
      <circle class="marker-pulse" cx="${job.x}" cy="${job.y}" r="14" fill="${c}" opacity="0.25"/>
      <circle class="marker-ring"  cx="${job.x}" cy="${job.y}" r="16" fill="none" stroke="${c}" stroke-width="2" opacity="0.6"/>
      <circle cx="${job.x}" cy="${job.y}" r="8" fill="${c}" stroke="#0c0e0f" stroke-width="2"/>
      <circle cx="${job.x}" cy="${job.y}" r="3" fill="#0c0e0f"/>`;
    g.addEventListener('click', () => openDetail(job.id));
    layer.appendChild(g);
  });
}

// ── JOB LIST ─────────────────────────────────────────────────────────────────
function buildJobList() {
  const el = document.getElementById('jobListEl');
  el.innerHTML = JOBS.map(j => `
    <div class="job-list-item" onclick="openDetail(${j.id})" data-type="${j.type}">
      <div class="job-list-dot" style="background:${COLORS[j.type]};box-shadow:0 0 5px ${COLORS[j.type]}"></div>
      <div>
        <div class="job-list-name">${j.name}</div>
        <div class="job-list-meta">${j.zone} · ${LABELS[j.type]}</div>
      </div>
    </div>`).join('');
}

// ── STATS ─────────────────────────────────────────────────────────────────────
function updateStats() {
  const counts = {};
  JOBS.forEach(j => { counts[j.type] = (counts[j.type]||0)+1; });
  document.getElementById('statActive').textContent  = counts.active  || 0;
  document.getElementById('statClosure').textContent = counts.closure || 0;
  document.getElementById('statTotal').textContent   = JOBS.length;
  ['active','closure','staging','planned','complete','hazard'].forEach(t => {
    document.getElementById('lc-'+t).textContent = counts[t]||0;
  });
}

// ── LAYERS ────────────────────────────────────────────────────────────────────
function toggleLayer(el) {
  const type = el.dataset.type;
  if (hiddenTypes.has(type)) { hiddenTypes.delete(type); el.classList.remove('hidden'); }
  else { hiddenTypes.add(type); el.classList.add('hidden'); }
  document.querySelectorAll('.marker-group').forEach(g => {
    g.style.display = hiddenTypes.has(g.dataset.type) ? 'none' : '';
  });
  document.querySelectorAll('.job-list-item').forEach(g => {
    g.style.display = hiddenTypes.has(g.dataset.type) ? 'none' : '';
  });
}

// ── DETAIL PANEL ──────────────────────────────────────────────────────────────
function openDetail(id) {
  if (id === 'base') {
    document.getElementById('detailBadge').textContent = 'HQ · SHADOW CONST.';
    document.getElementById('detailBadge').style.cssText =
      'background:#f5c40022;color:#f5c400;border:1px solid #f5c40055;font-family:\'Share Tech Mono\',monospace;font-size:9px;letter-spacing:2px;padding:3px 8px;border-radius:3px;';
    document.getElementById('detailName').textContent = 'Shadow Construction Base';
    document.getElementById('detailDesc').textContent = 'Main operations hub at postals 303 and 304. Equipment yard, crew staging, and dispatch centre. All jobs route through HQ.';
    document.getElementById('detailGrid').innerHTML = `
      <div class="detail-stat"><div class="detail-stat-label">POSTAL</div>      <div class="detail-stat-val">303 / 304</div></div>
      <div class="detail-stat"><div class="detail-stat-label">ZONE</div>        <div class="detail-stat-val">Georgia Ave</div></div>
      <div class="detail-stat"><div class="detail-stat-label">STATUS</div>      <div class="detail-stat-val">Operational</div></div>
      <div class="detail-stat"><div class="detail-stat-label">DISPATCH</div>    <div class="detail-stat-val">Discord</div></div>`;
    document.getElementById('detailPanel').classList.add('open');
    document.querySelectorAll('.marker-group').forEach(g => g.style.opacity = '0.45');
    return;
  }
  const job = JOBS.find(j => j.id === id);
  if (!job) return;
  activeJob = id;
  const c = COLORS[job.type];
  document.getElementById('detailBadge').textContent  = LABELS[job.type];
  document.getElementById('detailBadge').style.cssText =
    `background:${c}22;color:${c};border:1px solid ${c}55;font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:2px;padding:3px 8px;border-radius:3px;`;
  document.getElementById('detailName').textContent = job.name;
  document.getElementById('detailDesc').textContent = job.desc;
  document.getElementById('detailGrid').innerHTML = `
    <div class="detail-stat"><div class="detail-stat-label">ZONE</div>       <div class="detail-stat-val">${job.zone}</div></div>
    <div class="detail-stat"><div class="detail-stat-label">FOREMAN</div>    <div class="detail-stat-val">${job.foreman}</div></div>
    <div class="detail-stat"><div class="detail-stat-label">CREW SIZE</div>  <div class="detail-stat-val">${job.crew > 0 ? job.crew+' Workers' : '—'}</div></div>
    <div class="detail-stat"><div class="detail-stat-label">SESSION</div>    <div class="detail-stat-val">${job.session}</div></div>`;
  document.getElementById('detailPanel').classList.add('open');
  // highlight marker
  document.querySelectorAll('.marker-group').forEach(g => g.style.opacity = g.dataset.id == id ? '1' : '0.45');
}
function closeDetail() {
  document.getElementById('detailPanel').classList.remove('open');
  document.querySelectorAll('.marker-group').forEach(g => g.style.opacity = '1');
  activeJob = null;
}

// ── PAN / ZOOM ────────────────────────────────────────────────────────────────
function applyTransform() {
  document.getElementById('canvasInner').style.transform = `translate(${tx}px,${ty}px) scale(${scale})`;
}
function zoom(delta) {
  const wrap = document.getElementById('canvasWrap');
  const cx = wrap.clientWidth / 2, cy = wrap.clientHeight / 2;
  const newScale = Math.max(0.3, Math.min(3, scale + delta));
  tx = cx - (cx - tx) * (newScale / scale);
  ty = cy - (cy - ty) * (newScale / scale);
  scale = newScale;
  applyTransform();
}
function resetView() { fitMap(); }

// drag
const wrap = document.getElementById('canvasWrap');
wrap.addEventListener('mousedown', e => {
  dragging = true; startX = e.clientX; startY = e.clientY; startTx = tx; startTy = ty;
});
document.addEventListener('mousemove', e => {
  if (!dragging) return;
  tx = startTx + (e.clientX - startX);
  ty = startTy + (e.clientY - startY);
  applyTransform();
  const svgX = ((e.clientX - tx) / scale).toFixed(0);
  const svgY = ((e.clientY - ty) / scale).toFixed(0);
  document.getElementById('mapCoords').textContent = `X: ${svgX}  Y: ${svgY}`;
});
document.addEventListener('mouseup', () => { dragging = false; });

// scroll to zoom
wrap.addEventListener('wheel', e => {
  e.preventDefault();
  const delta = e.deltaY > 0 ? -0.12 : 0.12;
  const rect = wrap.getBoundingClientRect();
  const cx = e.clientX - rect.left, cy = e.clientY - rect.top;
  const newScale = Math.max(0.3, Math.min(3, scale + delta));
  tx = cx - (cx - tx) * (newScale / scale);
  ty = cy - (cy - ty) * (newScale / scale);
  scale = newScale;
  applyTransform();
}, { passive: false });

// touch support
let lastTouchDist = 0;
wrap.addEventListener('touchstart', e => {
  if (e.touches.length === 1) {
    dragging = true; startX = e.touches[0].clientX; startY = e.touches[0].clientY; startTx = tx; startTy = ty;
  } else if (e.touches.length === 2) {
    lastTouchDist = Math.hypot(e.touches[0].clientX-e.touches[1].clientX, e.touches[0].clientY-e.touches[1].clientY);
  }
});
wrap.addEventListener('touchmove', e => {
  e.preventDefault();
  if (e.touches.length === 1 && dragging) {
    tx = startTx + (e.touches[0].clientX - startX);
    ty = startTy + (e.touches[0].clientY - startY);
    applyTransform();
  } else if (e.touches.length === 2) {
    const d = Math.hypot(e.touches[0].clientX-e.touches[1].clientX, e.touches[0].clientY-e.touches[1].clientY);
    zoom((d - lastTouchDist) * 0.005);
    lastTouchDist = d;
  }
}, { passive: false });
wrap.addEventListener('touchend', () => { dragging = false; });

window.addEventListener('resize', fitMap);
init();
</script>
</body>
</html>
