<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head', {
  title: 'Shadow Construction — Fleet Livery Reference',
  fontsUrl: 'https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&family=Orbitron:wght@400;600;700;900&display=swap',
  cssFile: 'fleet.css'
}) %>
</head>
<body>

<!-- MAIN SITE -->
<div id="site" style="display:block;opacity:1;">

  <nav class="topnav">
    <a href="/" class="topnav-back">← Home</a>
    <div class="topnav-divider"></div>
    <a href="/" class="topnav-logo">SHADOW <span>CONSTRUCTION</span></a>
    <span class="topnav-label">FLEET REF</span>
    <a href="/wiki" class="topnav-wiki-link">📖 Wiki</a>
  </nav>

  <header class="site-header">
    <div class="header-inner">
      <div class="header-logo-wrap">
        <img class="header-logo-img" src="https://i.imgur.com/BCwBi9G.png" alt="Shadow Construction" onerror="this.style.display='none'">
      </div>
      <div class="header-text">
        <div class="header-eyebrow">// Internal Reference Document</div>
        <div class="header-title">SHADOW <span class="grad">CONSTRUCTION</span></div>
        <div class="header-subtitle">Fleet Livery Reference Sheet — All Vehicles</div>
      </div>
      <div class="header-stats">
        <div class="hstat">
          <div class="hstat-num"><%= vehicles.length %></div>
          <div class="hstat-label">Vehicles</div>
        </div>
        <div class="hstat">
          <div class="hstat-num"><%= totalSlots %></div>
          <div class="hstat-label">Livery Slots</div>
        </div>
      </div>
    </div>
    <div class="header-bar"></div>
  </header>

  <main class="content">
    <div class="sec-head">
      <div class="sec-tag">// Vehicle Fleet</div>
      <div class="sec-line"></div>
    </div>

    <!-- FILTER BAR -->
    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all" onclick="setFilter('all',this)">All Vehicles</button>
      <button class="filter-btn" data-filter="left"  onclick="setFilter('left',this)">Left Liveries</button>
      <button class="filter-btn" data-filter="right" onclick="setFilter('right',this)">Right Liveries</button>
      <button class="filter-btn" data-filter="back"  onclick="setFilter('back',this)">Back Liveries</button>
      <div class="filter-search">
        <span style="color:var(--muted);font-size:12px;">⌕</span>
        <input type="text" placeholder="Search vehicles..." oninput="searchVehicles(this.value)">
      </div>
    </div>

    <div class="vehicles-grid" id="vehicleGrid">
      <% vehicles.forEach(function(v, i) {
        const slots = v.liveries.map(l => l.slot.toLowerCase()).join(' ');
      %>
      <div class="vehicle-card"
           data-name="<%= v.name.toLowerCase() %>"
           data-slots="<%= slots %>"
           style="animation-delay: <%= (i * 0.04).toFixed(2) %>s">

        <div class="card-num"><%= String(i + 1).padStart(2, '0') %></div>

        <div class="card-head">
          <div class="vehicle-name"><%= v.name %></div>
          <% if (v.year || v.variant) { %>
          <div class="vehicle-meta">
            <% if (v.year) { %><span class="meta-pill year"><%= v.year %></span><% } %>
            <% if (v.variant) { %><span class="meta-pill variant"><%= v.variant %></span><% } %>
          </div>
          <% } %>
        </div>

        <div class="card-body">
          <table class="livery-table"><tbody>
            <% v.liveries.forEach(function(l) {
              let slotClass = 'left';
              if (l.slot.startsWith('Right')) slotClass = 'right';
              else if (l.slot.startsWith('Back')) slotClass = 'back';
            %>
            <tr>
              <td><span class="slot-badge <%= slotClass %>"><%= l.slot %></span></td>
              <td>
                <div class="livery-id">
                  <span><%= l.id %></span>
                  <button class="copy-btn" onclick="copyId(this,'<%= l.id %>')" title="Copy ID">⎘</button>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody></table>
        </div>

        <div class="card-colors">
          <% v.colors.forEach(function(c) { %>
          <div class="color-chip">
            <div class="chip-swatch" style="background:<%= c.hex %>"></div>
            <div>
              <span class="chip-label"><%= c.role %></span>
              <span class="chip-value"><%= c.hex.toUpperCase() %></span>
            </div>
          </div>
          <% }) %>
        </div>

      </div>
      <% }) %>
    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-left">
      <img class="footer-logo-img" src="https://i.imgur.com/BCwBi9G.png" alt="" onerror="this.style.display='none'">
      <div class="footer-brand">SHADOW <span>CONSTRUCTION</span></div>
    </div>
    <div class="footer-info"><%= vehicles.length %> vehicles · <%= totalSlots %> livery slots · internal use only</div>
  </footer>

</div><!-- /site -->

<div class="toast" id="toast">COPIED TO CLIPBOARD</div>

<script>
function copyId(btn, id) {
  navigator.clipboard.writeText(id).then(() => {
    btn.textContent = '✓'; btn.classList.add('copied');
    showToast();
    setTimeout(() => { btn.textContent = '⎘'; btn.classList.remove('copied'); }, 1800);
  });
}

function showToast() {
  const t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 1800);
}

let activeFilter = 'all';

function setFilter(filter, btn) {
  activeFilter = filter;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyFilters();
}

function searchVehicles(val) {
  document.querySelectorAll('.vehicle-card').forEach(card => {
    const name = card.dataset.name || '';
    card.classList.toggle('hidden', val !== '' && !name.includes(val.toLowerCase()));
  });
}

function applyFilters() {
  document.querySelectorAll('.vehicle-card').forEach(card => {
    if (activeFilter === 'all') { card.classList.remove('hidden'); return; }
    const slots = card.dataset.slots || '';
    card.classList.toggle('hidden', !slots.includes(activeFilter));
  });
}
</script>
</body>
</html>
