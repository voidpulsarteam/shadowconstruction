<!DOCTYPE html>
<html lang="en">
<head>
<%- include('partials/head', {
  title: 'Shadow Construction Co. | ER:LC Roleplay',
  fontsUrl: 'https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap',
  cssFile: 'index.css'
}) %>
</head>
<body>

<nav>
  <a href="/" class="nav-logo">
    <div class="nav-logo-icon">S</div>
    <span class="nav-logo-text">SHADOW <span>CONST</span></span>
    <span class="nav-badge">ER:LC</span>
  </a>
  <ul>
    <li><a href="#about">About</a></li>
    <li><a href="#roles">Roles</a></li>
    <li><a href="#rules">Rules</a></li>
    <li><a href="#ranks">Ranks</a></li>
    <li><a href="/wiki"  class="nav-wiki">📖 Wiki</a></li>
    <li><a href="/map"   class="nav-wiki">🗺️ Map</a></li>
    <li><a href="/fleet" class="nav-wiki">🚛 Fleet</a></li>
    <li><a href="#discord" class="nav-join">Join Us</a></li>
  </ul>
</nav>

<section id="hero">
  <div class="hero-grid-bg"></div>
  <p class="hero-tag">Emergency Response: Liberty County — Roleplay Group</p>
  <h1>
    SHADOW
    <span class="line-yellow">CONSTRUCTION</span>
    <span class="line-dim">LIBERTY COUNTY</span>
  </h1>
  <p class="hero-sub">Liberty County's most immersive <strong>construction roleplay experience</strong> on Roblox ER:LC. Build the city, play the crew, live the role.</p>
  <div class="hero-buttons">
    <a href="#discord" class="btn-yellow">🔨 Join the Crew</a>
    <a href="/wiki" class="btn-outline">📖 View Wiki</a>
  </div>
  <div class="hero-status">
    <div class="status-card"><div class="status-dot <%= site.status.group === 'ACTIVE' ? '' : 'orange' %>"></div><div class="status-text">GROUP STATUS: <span class="status-val"><%= site.status.group %></span></div></div>
    <div class="status-card"><div class="status-dot orange"></div><div class="status-text">SESSIONS: <span class="status-val"><%= site.status.sessions %></span></div></div>
    <div class="status-card"><div class="status-dot <%= site.status.applications === 'OPEN' ? '' : 'orange' %>"></div><div class="status-text">APPLICATIONS: <span class="status-val"><%= site.status.applications %></span></div></div>
  </div>
  <div class="hero-caution"></div>
</section>

<div class="caution-bar"></div>

<div id="wiki-strip">
  <div class="wiki-strip-left">
    <div class="wiki-strip-icon">📖</div>
    <div>
      <div class="wiki-strip-title">SHADOW <span>WIKI</span></div>
      <div class="wiki-strip-desc">Official docs, guides, and references for all Shadow Construction crew members.</div>
      <div class="wiki-strip-tags">
        <span class="wiki-tag">Radio Codes</span>
        <span class="wiki-tag">Uniform Guide</span>
        <span class="wiki-tag">Session Schedule</span>
        <span class="wiki-tag">Ranks & Promotions</span>
        <span class="wiki-tag">🗺️ Job Site Map</span>
      </div>
    </div>
  </div>
  <a href="/wiki" class="btn-yellow">Open Wiki →</a>
</div>

<section id="about">
  <div class="about-left">
    <p class="section-eyebrow">// WHO WE ARE</p>
    <h2 class="section-title">LIBERTY COUNTY'S<br><span class="accent">PREMIER CREW</span></h2>
    <p class="about-body">Shadow Construction Co. is a dedicated ER:LC roleplay group focused on delivering realistic, immersive construction scenarios in Liberty County. From road crews and site workers to foremen and project managers — we bring the job site to life.</p>
    <p class="about-body">Whether you're directing traffic around an active dig, operating heavy equipment, or laying down barriers at a road closure — every shift feels real. No trolling. No powergaming. Just quality RP.</p>
  </div>
  <div class="about-right">
    <div class="stat-box"><div class="stat-big"><%= site.stats.members %></div><div class="stat-label-box">Active Members</div></div>
    <div class="stat-box"><div class="stat-big"><%= site.stats.sessions %></div><div class="stat-label-box">Sessions Held</div></div>
    <div class="stat-box"><div class="stat-big"><%= site.stats.discord %></div><div class="stat-label-box">Discord Active</div></div>
    <div class="stat-box"><div class="stat-big"><%= site.stats.rank %></div><div class="stat-label-box">Construction RP</div></div>
  </div>
</section>

<div class="caution-bar"></div>

<section id="roles">
  <div class="roles-header">
    <div>
      <p class="section-eyebrow">// AVAILABLE POSITIONS</p>
      <h2 class="section-title">CREW <span class="accent">ROLES</span></h2>
    </div>
    <p style="font-size:13px;color:var(--gray);max-width:260px;text-align:right;line-height:1.6;">All roles are played during active sessions. Apply through Discord.</p>
  </div>
  <div class="roles-grid">
    <div class="role-card"><span class="role-icon">🦺</span><div class="role-name">Site Worker</div><p class="role-desc">Ground-level crew handling barriers, cones, tools, and physical labor on active construction sites.</p><span class="role-tag open">Open</span></div>
    <div class="role-card"><span class="role-icon">🚧</span><div class="role-name">Traffic Control</div><p class="role-desc">Manage civilian flow around job sites, operate signs, and coordinate with police for road closures.</p><span class="role-tag open">Open</span></div>
    <div class="role-card"><span class="role-icon">🚛</span><div class="role-name">Equipment Operator</div><p class="role-desc">Operate heavy machinery including cranes, forklifts, excavators, and dump trucks on active sites.</p><span class="role-tag limited">Limited</span></div>
    <div class="role-card"><span class="role-icon">📋</span><div class="role-name">Foreman</div><p class="role-desc">Lead the on-site crew, assign tasks, enforce safety, and report to management during sessions.</p><span class="role-tag limited">Limited</span></div>
    <div class="role-card"><span class="role-icon">🧰</span><div class="role-name">Electrician / Plumber</div><p class="role-desc">Specialized roleplay roles focusing on utility work, repairs, and infrastructure scenarios.</p><span class="role-tag open">Open</span></div>
    <div class="role-card"><span class="role-icon">🪖</span><div class="role-name">Safety Officer</div><p class="role-desc">Ensure all site workers follow RP safety protocols and handle on-site incident reports.</p><span class="role-tag open">Open</span></div>
    <div class="role-card"><span class="role-icon">📐</span><div class="role-name">Project Manager</div><p class="role-desc">Plan and execute session scenarios, coordinate with city departments, and oversee project scope.</p><span class="role-tag closed">Closed</span></div>
    <div class="role-card"><span class="role-icon">📸</span><div class="role-name">Media / PR</div><p class="role-desc">Document sessions, create content, manage socials, and help grow the Shadow Construction brand.</p><span class="role-tag open">Open</span></div>
  </div>
</section>

<div class="caution-bar"></div>

<section id="rules">
  <p class="section-eyebrow">// CODE OF CONDUCT</p>
  <h2 class="section-title">GROUP <span class="accent">RULES</span></h2>
  <div class="rules-grid">
    <div class="rule-item"><div class="rule-num">[01]</div><div><div class="rule-title">Respect All Members</div><p class="rule-text">Treat every crew member, civilian, and officer with respect in-game and in Discord. Harassment is an immediate strike.</p></div></div>
    <div class="rule-item"><div class="rule-num">[02]</div><div><div class="rule-title">Stay In Character</div><p class="rule-text">During active sessions, remain in character at all times. OOC chat belongs in designated channels only.</p></div></div>
    <div class="rule-item"><div class="rule-num">[03]</div><div><div class="rule-title">No Trolling or RDM</div><p class="rule-text">We are a serious RP group. Trolling, random deathmatch, and griefing sessions results in immediate removal.</p></div></div>
    <div class="rule-item"><div class="rule-num">[04]</div><div><div class="rule-title">Follow Chain of Command</div><p class="rule-text">Respect the rank structure. Issues escalate through proper channels — not public drama.</p></div></div>
    <div class="rule-item"><div class="rule-num">[05]</div><div><div class="rule-title">Attend Scheduled Sessions</div><p class="rule-text">Regular session attendance is required for active rank retention. Post in absence channel if you can't make it.</p></div></div>
    <div class="rule-item"><div class="rule-num">[06]</div><div><div class="rule-title">Wear the Uniform</div><p class="rule-text">All members must wear the approved Shadow Construction outfit during official sessions. Details in the wiki.</p></div></div>
    <div class="rule-item"><div class="rule-num">[07]</div><div><div class="rule-title">No Leaking or Raiding</div><p class="rule-text">Internal session plans and group documents are confidential. Leaking or coordinating raids = permanent ban.</p></div></div>
    <div class="rule-item"><div class="rule-num">[08]</div><div><div class="rule-title">Have Fun & RP Hard</div><p class="rule-text">Bring energy, creativity, and commitment to every session. That's what makes Shadow Construction stand out.</p></div></div>
  </div>
</section>

<section id="join">
  <p class="section-eyebrow">// RECRUITMENT</p>
  <h2 class="section-title">HOW TO <span class="accent">JOIN</span></h2>
  <div class="steps">
    <div class="step"><div class="step-num">01</div><div class="step-title">Join Discord</div><p class="step-desc">Click the Join button to enter our Discord server and read the welcome channel carefully.</p></div>
    <div class="step"><div class="step-num">02</div><div class="step-title">Read the Wiki</div><p class="step-desc">Go through the rules, handbook, and wiki docs — your application will test your knowledge.</p></div>
    <div class="step"><div class="step-num">03</div><div class="step-title">Apply</div><p class="step-desc">Fill out the application form in #apply. Choose your preferred role and available shift time.</p></div>
    <div class="step"><div class="step-num">04</div><div class="step-title">Get Trained</div><p class="step-desc">If accepted, attend your onboarding session. Get your rank, uniform, and first assignment.</p></div>
  </div>
</section>

<div class="caution-bar"></div>

<section id="ranks">
  <p class="section-eyebrow">// RANK STRUCTURE</p>
  <h2 class="section-title">CREW <span class="accent">RANKS</span></h2>
  <div class="ranks-list">
    <div class="rank-row"><div class="rank-tier">TIER 5</div><div class="rank-name gold">⭐ CEO / Founder</div><div class="rank-desc">Leads the entire organization, sets group direction, and has final authority on all decisions.</div><span class="rank-badge badge-management">Management</span></div>
    <div class="rank-row"><div class="rank-tier">TIER 4</div><div class="rank-name gold">🔱 Co-Owner / Director</div><div class="rank-desc">Assists leadership, manages department heads, handles disciplinary actions and promotions.</div><span class="rank-badge badge-management">Management</span></div>
    <div class="rank-row"><div class="rank-tier">TIER 3</div><div class="rank-name silver">🪖 Project Manager</div><div class="rank-desc">Organizes and leads sessions, assigns foremen, and coordinates large-scale construction scenarios.</div><span class="rank-badge badge-senior">Senior</span></div>
    <div class="rank-row"><div class="rank-tier">TIER 3</div><div class="rank-name silver">📋 Foreman</div><div class="rank-desc">Supervises on-site workers, enforces safety protocols, and reports to Project Manager.</div><span class="rank-badge badge-senior">Senior</span></div>
    <div class="rank-row"><div class="rank-tier">TIER 2</div><div class="rank-name bronze">🚛 Senior Worker</div><div class="rank-desc">Experienced crew member eligible for specialized roles and equipment operator assignments.</div><span class="rank-badge badge-worker">Worker</span></div>
    <div class="rank-row"><div class="rank-tier">TIER 2</div><div class="rank-name bronze">🦺 Worker</div><div class="rank-desc">Full crew member assigned regular roles. Eligible to attend all official sessions.</div><span class="rank-badge badge-worker">Worker</span></div>
    <div class="rank-row"><div class="rank-tier">TIER 1</div><div class="rank-name green">🟢 Trainee</div><div class="rank-desc">New recruit in onboarding. Completing training sessions to earn full Worker rank.</div><span class="rank-badge badge-trainee">Trainee</span></div>
  </div>
</section>

<section id="discord">
  <div class="discord-bg"></div>
  <div style="position:relative;">
    <p style="font-size:56px;margin-bottom:20px;">🔨</p>
    <h2 class="discord-title">READY TO BUILD?</h2>
    <p class="discord-sub">Join the Shadow Construction Discord to apply, check session times, and meet the crew.</p>
    <a href="#" class="discord-btn">
      <svg width="22" height="16" viewBox="0 0 24 18" fill="white"><path d="M20.317 1.492a19.825 19.825 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.249a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.249.077.077 0 00-.079-.037A19.736 19.736 0 003.677 1.492a.07.07 0 00-.032.027C.533 6.093-.32 10.555.099 14.961a.08.08 0 00.031.055 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994.021-.041.001-.09-.041-.106a13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.927 1.793 8.18 1.793 12.061 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.442a.061.061 0 00-.031-.028z"/></svg>
      Join Our Discord
    </a>
  </div>
</section>

<footer>
  <div>
    <a href="/" class="footer-logo">SHADOW <span>CONST.</span></a>
    <p class="footer-small">ER:LC Roleplay Group · Liberty County · Roblox</p>
  </div>
  <ul class="footer-links">
    <li><a href="#about">About</a></li>
    <li><a href="#roles">Roles</a></li>
    <li><a href="#rules">Rules</a></li>
    <li><a href="#ranks">Ranks</a></li>
    <li><a href="/wiki">📖 Wiki</a></li>
    <li><a href="/map">🗺️ Map</a></li>
    <li><a href="/fleet">🚛 Fleet</a></li>
    <li><a href="#discord">Discord</a></li>
  </ul>
  <div class="footer-right">
    <div>© 2025 Shadow Construction Co.</div>
    <div style="color:var(--border)">Fan group — not affiliated with Roblox or ER:LC devs</div>
  </div>
</footer>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.style.opacity='1'; e.target.style.transform='translateY(0)'; obs.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.role-card,.rule-item,.step,.rank-row,.stat-box').forEach((el,i) => {
    el.style.opacity='0'; el.style.transform='translateY(20px)';
    el.style.transition=`opacity 0.5s ${i*0.06}s ease, transform 0.5s ${i*0.06}s ease`;
    obs.observe(el);
  });
</script>
</body>
</html>
