<!DOCTYPE html>
<html lang="en">
<head>
<%- include('../partials/head', {
  title: (isNew ? 'Add Vehicle' : 'Edit Vehicle') + ' — Dashboard',
  fontsUrl: 'https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&family=Orbitron:wght@400;600;700;900&display=swap',
  cssFile: 'dashboard.css'
}) %>
</head>
<body>

<div class="topbar">
  <a href="/dashboard" class="topbar-brand">SHADOW <span>CONSTRUCTION</span></a>
  <span class="topbar-badge">DASHBOARD</span>
  <div class="topbar-right">
    <span class="topbar-user">Signed in as <span><%= user.username %></span></span>
    <a href="/logout" class="topbar-link danger">Sign Out</a>
  </div>
</div>

<div class="dash-layout">
  <%- include('../partials/dash-nav', { page: 'fleet' }) %>

  <main class="dash-main">
    <% if (flash.error && flash.error.length) { %>
      <div class="flash flash-error">⚠ <%= flash.error[0] %></div>
    <% } %>

    <div class="page-header">
      <div class="page-eyebrow">// Fleet Manager</div>
      <div class="page-title"><%= isNew ? 'ADD' : 'EDIT' %> <span>VEHICLE</span></div>
      <% if (!isNew) { %><div class="page-desc"><%= vehicle.name %></div><% } %>
    </div>

    <form method="POST" action="<%= isNew ? '/dashboard/fleet/new' : '/dashboard/fleet/' + index + '/edit' %>">

      <!-- Basic Info -->
      <div class="form-card" style="margin-bottom:16px;">
        <div class="section-title" style="margin-bottom:16px;">// Vehicle Info</div>
        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label">Vehicle Name *</label>
            <input class="form-input" type="text" name="name" value="<%= vehicle.name %>" placeholder="e.g. Falcon Advance 450 Tow Truck" required>
          </div>
          <div class="form-group">
            <label class="form-label">Year</label>
            <input class="form-input" type="text" name="year" value="<%= vehicle.year %>" placeholder="e.g. 2020">
          </div>
          <div class="form-group">
            <label class="form-label">Variant</label>
            <input class="form-input" type="text" name="variant" value="<%= vehicle.variant %>" placeholder="e.g. Variant A">
          </div>
        </div>
      </div>

      <!-- Liveries -->
      <div class="form-card" style="margin-bottom:16px;">
        <div class="section-title" style="margin-bottom:14px;">// Livery Slots</div>
        <div class="livery-rows" id="liveryRows">
          <% vehicle.liveries.forEach(function(l, i) { %>
          <div class="livery-row">
            <input class="form-input" type="text" name="livery_slot[]" value="<%= l.slot %>" placeholder="Left1" style="margin:0;">
            <input class="form-input" type="text" name="livery_id[]"   value="<%= l.id %>"   placeholder="Livery ID" style="margin:0;font-family:'Share Tech Mono',monospace;font-size:13px;">
            <button type="button" class="row-remove" onclick="removeRow(this)" title="Remove">✕</button>
          </div>
          <% }) %>
        </div>
        <button type="button" class="add-row-btn" onclick="addLivery()">+ Add Livery Slot</button>
      </div>

      <!-- Colors -->
      <div class="form-card" style="margin-bottom:24px;">
        <div class="section-title" style="margin-bottom:14px;">// Paint Colors</div>
        <div class="color-rows" id="colorRows">
          <% vehicle.colors.forEach(function(c) { %>
          <div class="color-row">
            <input class="form-input" type="text"  name="color_role[]" value="<%= c.role %>" placeholder="Primary" style="margin:0;">
            <input type="color" name="color_hex[]" value="<%= c.hex %>">
            <span class="mono" style="font-size:11px;color:var(--muted);"><%= c.hex.toUpperCase() %></span>
            <button type="button" class="row-remove" onclick="removeRow(this)" title="Remove">✕</button>
          </div>
          <% }) %>
        </div>
        <button type="button" class="add-row-btn" onclick="addColor()">+ Add Color</button>
      </div>

      <!-- Actions -->
      <div style="display:flex;gap:10px;align-items:center;">
        <button class="btn btn-primary" type="submit"><%= isNew ? '+ Add Vehicle' : '✓ Save Changes' %></button>
        <a href="/dashboard/fleet" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </main>
</div>

<script>
function removeRow(btn) {
  const row = btn.closest('.livery-row, .color-row');
  row.remove();
}

function addLivery() {
  const container = document.getElementById('liveryRows');
  const div = document.createElement('div');
  div.className = 'livery-row';
  div.innerHTML = `
    <input class="form-input" type="text" name="livery_slot[]" placeholder="Left1" style="margin:0;">
    <input class="form-input" type="text" name="livery_id[]"   placeholder="Livery ID" style="margin:0;font-family:'Share Tech Mono',monospace;font-size:13px;">
    <button type="button" class="row-remove" onclick="removeRow(this)" title="Remove">✕</button>
  `;
  container.appendChild(div);
  div.querySelector('input').focus();
}

function addColor() {
  const container = document.getElementById('colorRows');
  const div = document.createElement('div');
  div.className = 'color-row';
  div.innerHTML = `
    <input class="form-input" type="text"  name="color_role[]" placeholder="Secondary" style="margin:0;">
    <input type="color" name="color_hex[]" value="#303030">
    <span class="mono" style="font-size:11px;color:var(--muted);">#303030</span>
    <button type="button" class="row-remove" onclick="removeRow(this)" title="Remove">✕</button>
  `;
  container.appendChild(div);

  // Live hex label update
  const colorInput = div.querySelector('input[type=color]');
  const hexLabel   = div.querySelector('.mono');
  colorInput.addEventListener('input', () => { hexLabel.textContent = colorInput.value.toUpperCase(); });
}

// Live hex label updates for existing rows
document.querySelectorAll('.color-row').forEach(row => {
  const colorInput = row.querySelector('input[type=color]');
  const hexLabel   = row.querySelector('.mono');
  if (colorInput && hexLabel) {
    colorInput.addEventListener('input', () => { hexLabel.textContent = colorInput.value.toUpperCase(); });
  }
});
</script>
</body>
</html>
