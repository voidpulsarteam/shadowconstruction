<!DOCTYPE html>
<html lang="en">
<head>
<%- include('../partials/head', {
  title: 'Site Settings — Dashboard',
  fontsUrl: 'https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&family=Orbitron:wght@400;600;700;900&display=swap',
  cssFile: 'dashboard.css'
}) %>
</head>
<body>

<div class="topbar">
  <a href="/dashboard" class="topbar-brand">SHADOW <span>CONSTRUCTION</span></a>
  <span class="topbar-badge">DASHBOARD</span>
  <div class="topbar-right">
    <span class="topbar-user">Signed in as <span><%= user.username %></span></span>
    <a href="/" target="_blank" class="topbar-link">Main Site ↗</a>
    <a href="/logout" class="topbar-link danger">Sign Out</a>
  </div>
</div>

<div class="dash-layout">
  <%- include('../partials/dash-nav', { page: 'site' }) %>

  <main class="dash-main">
    <% if (flash.success && flash.success.length) { %>
      <div class="flash flash-success">✓ <%= flash.success[0] %></div>
    <% } %>
    <% if (flash.error && flash.error.length) { %>
      <div class="flash flash-error">⚠ <%= flash.error[0] %></div>
    <% } %>

    <div class="page-header">
      <div class="page-eyebrow">// Content Management</div>
      <div class="page-title">SITE <span>SETTINGS</span></div>
      <div class="page-desc">Update the homepage status indicators and group statistics.</div>
    </div>

    <form method="POST" action="/dashboard/site">

      <!-- Status -->
      <div class="form-card" style="margin-bottom:16px;">
        <div class="section-title" style="margin-bottom:16px;">// Homepage Status Badges</div>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Group Status</label>
            <select class="form-select" name="group">
              <option value="ACTIVE"      <%= site.status.group === 'ACTIVE'      ? 'selected' : '' %>>ACTIVE</option>
              <option value="INACTIVE"    <%= site.status.group === 'INACTIVE'    ? 'selected' : '' %>>INACTIVE</option>
              <option value="MAINTENANCE" <%= site.status.group === 'MAINTENANCE' ? 'selected' : '' %>>MAINTENANCE</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Sessions</label>
            <select class="form-select" name="sessions">
              <option value="WEEKLY"        <%= site.status.sessions === 'WEEKLY'        ? 'selected' : '' %>>WEEKLY</option>
              <option value="PAUSED"        <%= site.status.sessions === 'PAUSED'        ? 'selected' : '' %>>PAUSED</option>
              <option value="SPECIAL EVENTS"<%= site.status.sessions === 'SPECIAL EVENTS'? 'selected' : '' %>>SPECIAL EVENTS</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Applications</label>
            <select class="form-select" name="applications">
              <option value="OPEN"      <%= site.status.applications === 'OPEN'      ? 'selected' : '' %>>OPEN</option>
              <option value="CLOSED"    <%= site.status.applications === 'CLOSED'    ? 'selected' : '' %>>CLOSED</option>
              <option value="SELECTIVE" <%= site.status.applications === 'SELECTIVE' ? 'selected' : '' %>>SELECTIVE</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="form-card" style="margin-bottom:24px;">
        <div class="section-title" style="margin-bottom:16px;">// Homepage Statistics</div>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Active Members</label>
            <input class="form-input" type="text" name="members" value="<%= site.stats.members %>" placeholder="50+">
          </div>
          <div class="form-group">
            <label class="form-label">Sessions Held</label>
            <input class="form-input" type="text" name="statSessions" value="<%= site.stats.sessions %>" placeholder="100+">
          </div>
          <div class="form-group">
            <label class="form-label">Discord Status</label>
            <input class="form-input" type="text" name="discord" value="<%= site.stats.discord %>" placeholder="24/7">
          </div>
          <div class="form-group">
            <label class="form-label">Rank / Tagline</label>
            <input class="form-input" type="text" name="rank" value="<%= site.stats.rank %>" placeholder="#1">
          </div>
        </div>
      </div>

      <button class="btn btn-primary" type="submit">✓ Save Settings</button>
    </form>
  </main>
</div>
</body>
</html>
