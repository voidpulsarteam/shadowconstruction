<!DOCTYPE html>
<html lang="en">
<head>
<%- include('../partials/head', {
  title: 'Fleet Manager — Dashboard',
  fontsUrl: 'https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&family=Orbitron:wght@400;600;700;900&display=swap',
  cssFile: 'dashboard.css'
}) %>
</head>
<body>

<div class="topbar">
  <a href="/dashboard" class="topbar-brand">SHADOW <span>CONSTRUCTION</span></a>
  <span class="topbar-badge">DASHBOARD</span>
  <div class="topbar-right">
    <span class="topbar-user">Signed in as <span><%= user.username %></span></span>
    <a href="/fleet" target="_blank" class="topbar-link">Fleet Page ↗</a>
    <a href="/logout" class="topbar-link danger">Sign Out</a>
  </div>
</div>

<div class="dash-layout">
  <%- include('../partials/dash-nav', { page: 'fleet' }) %>

  <main class="dash-main">
    <% if (flash.success && flash.success.length) { %>
      <div class="flash flash-success">✓ <%= flash.success[0] %></div>
    <% } %>
    <% if (flash.error && flash.error.length) { %>
      <div class="flash flash-error">⚠ <%= flash.error[0] %></div>
    <% } %>

    <div class="page-header">
      <div class="page-eyebrow">// Content Management</div>
      <div class="page-title">FLEET <span>MANAGER</span></div>
      <div class="page-desc"><%= vehicles.length %> vehicles · <%= vehicles.reduce((s,v)=>s+v.liveries.length,0) %> total livery slots</div>
    </div>

    <div class="dash-section">
      <div class="section-header">
        <div class="section-title">// All Vehicles</div>
        <a href="/dashboard/fleet/new" class="btn btn-primary btn-sm">+ Add Vehicle</a>
      </div>

      <% if (vehicles.length === 0) { %>
        <div class="empty-state">No vehicles yet. <a href="/dashboard/fleet/new" style="color:var(--accent2);">Add one →</a></div>
      <% } else { %>
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Vehicle Name</th>
            <th>Year</th>
            <th>Variant</th>
            <th>Slots</th>
            <th>Colors</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% vehicles.forEach(function(v, i) { %>
          <tr>
            <td class="mono"><%= String(i+1).padStart(2,'0') %></td>
            <td><strong><%= v.name %></strong></td>
            <td class="mono"><%= v.year || '—' %></td>
            <td><% if (v.variant) { %><span class="badge badge-cyan"><%= v.variant %></span><% } else { %><span style="color:var(--muted2)">—</span><% } %></td>
            <td class="mono"><%= v.liveries.length %></td>
            <td>
              <div style="display:flex;gap:4px;">
                <% v.colors.forEach(function(c) { %>
                  <span class="swatch-preview" style="background:<%= c.hex %>" title="<%= c.role %>: <%= c.hex %>"></span>
                <% }) %>
              </div>
            </td>
            <td>
              <div class="actions">
                <a href="/dashboard/fleet/<%= i %>/edit" class="btn btn-outline btn-sm">Edit</a>
                <form method="POST" action="/dashboard/fleet/<%= i %>/delete" style="display:inline;" onsubmit="return confirm('Delete <%= v.name.replace(/'/g, "\\'") %>?')">
                  <button class="btn btn-danger btn-sm" type="submit">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
