<!DOCTYPE html>
<html lang="en">
<head>
<%- include('../partials/head', {
  title: 'Dashboard — Shadow Construction',
  fontsUrl: 'https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&family=Orbitron:wght@400;600;700;900&display=swap',
  cssFile: 'dashboard.css'
}) %>
</head>
<body>

<div class="topbar">
  <a href="/dashboard" class="topbar-brand">SHADOW <span>CONSTRUCTION</span></a>
  <span class="topbar-badge">DASHBOARD</span>
  <div class="topbar-right">
    <span class="topbar-user">Signed in as <span><%= user.username %></span></span>
    <a href="/fleet" target="_blank" class="topbar-link">Fleet Page ↗</a>
    <a href="/logout" class="topbar-link danger">Sign Out</a>
  </div>
</div>

<div class="dash-layout">
  <%- include('../partials/dash-nav', { page: 'home' }) %>

  <main class="dash-main">
    <% if (flash.success && flash.success.length) { %>
      <div class="flash flash-success">✓ <%= flash.success[0] %></div>
    <% } %>
    <% if (flash.error && flash.error.length) { %>
      <div class="flash flash-error">⚠ <%= flash.error[0] %></div>
    <% } %>

    <div class="page-header">
      <div class="page-eyebrow">// Admin Panel</div>
      <div class="page-title">DASHBOARD <span>HOME</span></div>
      <div class="page-desc">Manage fleet vehicles and site content from here.</div>
    </div>

    <!-- Stats -->
    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-num"><%= vehicles.length %></div>
        <div class="stat-label">Fleet Vehicles</div>
      </div>
      <div class="stat-card">
        <div class="stat-num"><%= totalSlots %></div>
        <div class="stat-label">Livery Slots</div>
      </div>
      <div class="stat-card">
        <div class="stat-num"><%= site.status.group %></div>
        <div class="stat-label">Group Status</div>
      </div>
      <div class="stat-card">
        <div class="stat-num"><%= site.status.applications %></div>
        <div class="stat-label">Applications</div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="dash-section">
      <div class="section-header">
        <div class="section-title">// Quick Actions</div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <a href="/dashboard/fleet/new" class="btn btn-primary">+ Add Vehicle</a>
        <a href="/dashboard/fleet"     class="btn btn-outline">🚛 Fleet Manager</a>
        <a href="/dashboard/site"      class="btn btn-outline">⚙️ Site Settings</a>
        <a href="/dashboard/password"  class="btn btn-outline">🔑 Change Password</a>
      </div>
    </div>

    <!-- Recent Fleet -->
    <div class="dash-section">
      <div class="section-header">
        <div class="section-title">// Fleet Overview</div>
        <a href="/dashboard/fleet" class="btn btn-outline btn-sm">View All</a>
      </div>
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Vehicle</th>
            <th>Year</th>
            <th>Slots</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% vehicles.slice(0, 6).forEach(function(v, i) { %>
          <tr>
            <td class="mono"><%= String(i+1).padStart(2,'0') %></td>
            <td><strong><%= v.name %></strong><% if (v.variant) { %> <span class="badge badge-cyan"><%= v.variant %></span><% } %></td>
            <td class="mono"><%= v.year || '—' %></td>
            <td class="mono"><%= v.liveries.length %></td>
            <td><div class="actions"><a href="/dashboard/fleet/<%= i %>/edit" class="btn btn-outline btn-sm">Edit</a></div></td>
          </tr>
          <% }) %>
          <% if (vehicles.length > 6) { %>
          <tr>
            <td colspan="5" style="text-align:center;color:var(--muted);font-family:'Share Tech Mono',monospace;font-size:10px;padding:12px;">
              + <%= vehicles.length - 6 %> more — <a href="/dashboard/fleet" style="color:var(--accent2);">view all</a>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>

  </main>
</div>
</body>
</html>
